#include <stdio.h>

int main() {
    char p[100], key[] = "QWERTYUIOPASDFGHJKLZXCVBNM";
    int i;

    printf("Enter text: ");
    scanf("%s", p);

    for (i = 0; p[i] != '\0'; i++) {
        if (p[i] >= 'A' && p[i] <= 'Z')
            p[i] = key[p[i] - 'A'];
        else if (p[i] >= 'a' && p[i] <= 'z')
            p[i] = key[p[i] - 'a'] + 32;   // Convert back to lowercase
    }

    printf("Encrypted text: %s", p);
    return 0;
}

//EXP3
#include <stdio.h>
#include <string.h>

char key[5][5] = {
    {'M','O','N','A','R'},
    {'C','H','Y','B','D'},
    {'E','F','G','I','K'},
    {'L','P','Q','S','T'},
    {'U','V','W','X','Z'}
};

void find(char c, int *r, int *col) {
    if (c == 'J') c = 'I';
    for (int i = 0; i < 5; i++)
        for (int j = 0; j < 5; j++)
            if (key[i][j] == c) {
                *r = i;
                *col = j;
            }
}

int main() {
    char p[100];
    int r1, c1, r2, c2;

    printf("Enter plaintext (2 letters): ");
    scanf("%s", p);

    find(p[0], &r1, &c1);
    find(p[1], &r2, &c2);

    if (r1 == r2) {
        printf("Cipher: %c%c\n", key[r1][(c1 + 1) % 5], key[r2][(c2 + 1) % 5]);
    } else if (c1 == c2) {
        printf("Cipher: %c%c\n", key[(r1 + 1) % 5][c1], key[(r2 + 1) % 5][c2]);
    } else {
        printf("Cipher: %c%c\n", key[r1][c2], key[r2][c1]);
    }

    return 0;
}
