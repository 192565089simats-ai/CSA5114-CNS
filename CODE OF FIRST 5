#include <stdio.h>

int main() {
    char text[100];
    int a, b, i;

    printf("Enter plaintext (UPPERCASE): ");
    scanf("%s", text);

    printf("Enter values of a and b: ");
    scanf("%d%d", &a, &b);

    for (i = 0; text[i] != '\0'; i++) {
        text[i] = ((a * (text[i] - 'A') + b) % 26) + 'A';
    }

    printf("Encrypted text: %s", text);

    return 0;
}

